# Postgres
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_USER="root"
POSTGRES_PASSWORD="mysecretpassword"
POSTGRES_DB="local"

ORIGIN="http://localhost:5173"

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# --- Sign-in methods ---
# uprox is invite-only: the first account is created via the one-time /setup
# wizard, everyone else joins through an organization invitation or OIDC.
#
# Email + password login is on by default. Set to "true" to turn it off and
# rely solely on OIDC (note: invitees then need accounts provisioned via OIDC,
# since accepting an invite by email requires a password account).
EMAIL_AUTH_DISABLED="false"

# Optional single OIDC provider (Authentik, Keycloak, Entra ID, Auth0, …).
# Set all three to enable a "Sign in with SSO" button. Leave blank to disable.
# The redirect/callback URL to register with your provider is:
#   {ORIGIN}/api/auth/oauth2/callback/oidc
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
# Optional: button label and requested scopes (comma-separated).
OIDC_PROVIDER_NAME="Single sign-on"
OIDC_SCOPES="openid,email,profile"

# Master key for AES-256-GCM encryption of provider secrets.
# 32 bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# --- Email (optional) ---
# SMTP transport for member-invitation emails. When SMTP_HOST is unset, invites
# still work: the dashboard shows a copy-able invite link instead of sending mail.
# Real delivery also requires installing nodemailer: `pnpm add nodemailer`.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="uprox <no-reply@example.com>"

# --- examples/ only (pnpm example, pnpm example:provision) ---
# Machine token used by examples/use-gateway.ts (mint one in the dashboard or
# via `pnpm example:provision`).
UPROX_TOKEN=""
# Gateway base URL the example talks to.
UPROX_URL="http://localhost:5173/v1"
# Real upstream key — set this so example:provision stores a working OpenAI key.
OPENAI_API_KEY=""
