{
	"name": "uprox",
	"private": true,
	"version": "0.2.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm test:unit --run && pnpm test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:start": "docker compose up",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"example": "tsx --env-file-if-exists=.env examples/use-gateway.ts",
		"example:provision": "tsx --env-file-if-exists=.env examples/provision.mjs",
		"changelog": "git-cliff -o CHANGELOG.md"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.16.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^25",
		"@types/nodemailer": "^8.0.0",
		"@vitest/browser-playwright": "^4.1.7",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "3.17.1",
		"formsnap": "^2.0.1",
		"git-cliff": "^2.13.1",
		"globals": "^17.6.0",
		"layerchart": "2.0.0-next.48",
		"mode-watcher": "^1.1.0",
		"openai": "^6.39.0",
		"paneforge": "^1.0.2",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.0.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "1.2.7",
		"svelte": "5.55.9",
		"svelte-check": "^4.4.8",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.3",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.14",
		"vitest": "^4.1.7",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"better-auth": "^1.6.11",
		"drizzle-orm": "^0.45.2",
		"nodemailer": "^8.0.9",
		"postgres": "^3.4.9"
	}
}
